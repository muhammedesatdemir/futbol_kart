# =============================================================================
# Futbol Kart Oyunu — environment variables
# Bu dosyayı .env.local olarak kopyala, değerleri kendi hesaplarından al.
# =============================================================================

# Neon Postgres connection string
# https://console.neon.tech → project → Connection Details → "Pooled connection"
DATABASE_URL="postgresql://user:password@ep-something-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Better-Auth secret (32+ karakter rastgele string)
# Üretmek için: `openssl rand -base64 32`  (veya https://www.uuidgenerator.net/)
BETTER_AUTH_SECRET="paste-a-strong-random-secret-here"

# Better-Auth base URL — dev için localhost, prod'da kendi domain'in
BETTER_AUTH_URL="http://localhost:3000"

# Client tarafının da bilmesi gereken aynı URL (Better-Auth client config için)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend API key — magic-link e-postaları için
# https://resend.com → API Keys → Create
# Boş bırakırsan magic link konsola yazdırılır (geliştirme için).
RESEND_API_KEY=""

# Magic-link e-postalarının gönderildiği "From" adresi
# Resend'de bir domain doğrulamadan önce: "onboarding@resend.dev" kullanabilirsin.
# Kendi domain'ini ekledikten sonra: "Futbol Kart <noreply@seninsiten.com>"
EMAIL_FROM="onboarding@resend.dev"

# -----------------------------------------------------------------------------
# Google OAuth — "Google ile devam et" girişi için (online mod ana giriş yolu)
# Boş bırakırsan Google butonu gizlenir, yalnızca e-posta magic-link çalışır.
#
# Kurulum:
#   1. https://console.cloud.google.com → yeni proje
#   2. "APIs & Services" → "OAuth consent screen" → External, uygulama adı/destek e-postası
#   3. "Credentials" → "Create Credentials" → "OAuth client ID" → Web application
#   4. Authorized redirect URIs'e ekle:
#        http://localhost:3000/api/auth/callback/google   (dev)
#        https://senindomainin.com/api/auth/callback/google (prod)
#   5. Oluşan Client ID ve Client Secret'ı buraya yapıştır.
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Client tarafında "Google ile devam et" butonunu göstermek için.
# Google'ı yukarıda kurduysan "true" yap; aksi halde buton gizli kalır.
NEXT_PUBLIC_GOOGLE_ENABLED="false"
